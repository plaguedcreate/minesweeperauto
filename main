local _W = game:GetService("Workspace")
local _RS = game:GetService("RunService")
local _P = game:GetService("Players")
local PathfindingService = game:GetService("PathfindingService")

local Visuals = {
    M_COL = Color3.fromRGB(255, 40, 40),
    S_COL = Color3.fromRGB(0, 160, 255),
    THICK = 0.15,
}

local Prefs = { 
    Active = true,
    TotalMines = 100
}

local Memory = {
    Map = { Grid = {}, Marked = {}, ToFlag = {}, ToClear = {} },
    Bounds = { X = 0, Z = 0 },
    Count = -1,
    Pending = false,
    Links = {}
}

local m_abs, m_floor, m_huge = math.abs, math.floor, math.huge
local t_sort = table.sort

local function RefreshBox(obj, mode)
    if not obj or not obj.part then return end
    if obj.lastMode == mode then return end
    obj.lastMode = mode

    local box = obj.part:FindFirstChild("SolverHighlight")
    if mode == "none" then
        if box then box:Destroy() end
        return
    end

    if not box then
        box = Instance.new("SelectionBox")
        box.Name = "SolverHighlight"
        box.Parent = obj.part
        box.Adornee = obj.part
        box.LineThickness = Visuals.THICK
        box.SurfaceTransparency = 1 
    end
    box.Color3 = (mode == "mine" and Visuals.M_COL) or Visuals.S_COL
    box.Transparency = 0
end

local function BindFolder(target)
    for _, v in ipairs(Memory.Links) do v:Disconnect() end
    Memory.Links = {}
    
    table.insert(Memory.Links, target.DescendantAdded:Connect(function()
        if not Memory.Pending then
            Memory.Pending = true
        end
    end))

    table.insert(Memory.Links, target.DescendantRemoving:Connect(function()
        Memory.Pending = true
    end))
end

local function MapOutEnvironment(src)
    Memory.Map.Grid = {}
    local items = src:GetChildren()
    if #items == 0 then return end

    local raw, xCoords, zCoords = {}, {}, {}
    for _, p in ipairs(items) do
        if p:IsA("BasePart") and p.Transparency < 0.5 then
            table.insert(raw, {obj = p, loc = p.Position})
            table.insert(xCoords, p.Position.X)
            table.insert(zCoords, p.Position.Z)
        end
    end
    if #xCoords == 0 then return end
    t_sort(xCoords) t_sort(zCoords)

    local function Group(set)
        local res = {}
        local v, n = set[1], 1
        for i = 2, #set do
            if m_abs(set[i] - v) <= 2 then
                n = n + 1
                v = v + (set[i] - v) / n
            else
                table.insert(res, v)
                v, n = set[i], 1
            end
        end
        table.insert(res, v)
        return res
    end

    local uX, uZ = Group(xCoords), Group(zCoords)
    Memory.Bounds.X, Memory.Bounds.Z = #uX, #uZ

    for x = 0, Memory.Bounds.X - 1 do
        Memory.Map.Grid[x] = {}
        for z = 0, Memory.Bounds.Z - 1 do
            Memory.Map.Grid[x][z] = {
                ix = x, iz = z, adj = {}, status = "unknown", hidden = true
            }
        end
    end

    for _, d in ipairs(raw) do
        local rX, rZ = 1, 1
        local dX, dZ = m_huge, m_huge
        for i, v in ipairs(uX) do if m_abs(d.loc.X - v) < dX then dX = m_abs(d.loc.X - v) rX = i end end
        for i, v in ipairs(uZ) do if m_abs(d.loc.Z - v) < dZ then dZ = m_abs(d.loc.Z - v) rZ = i end end
        local unit = Memory.Map.Grid[rX-1][rZ-1]
        unit.part = d.obj
        unit.pos = d.loc
    end

    for x = 0, Memory.Bounds.X - 1 do
        for z = 0, Memory.Bounds.Z - 1 do
            local unit = Memory.Map.Grid[x][z]
            for ox = -1, 1 do
                for oz = -1, 1 do
                    if not (ox == 0 and oz == 0) then
                        local nx, nz = x + ox, z + oz
                        if Memory.Map.Grid[nx] and Memory.Map.Grid[nx][nz] then
                            table.insert(unit.adj, Memory.Map.Grid[nx][nz])
                        end
                    end
                end
            end
        end
    end
    BindFolder(src)
end

local function ScanGrid()
    Memory.Map.Marked = {}
    for x = 0, Memory.Bounds.X - 1 do
        for z = 0, Memory.Bounds.Z - 1 do
            local unit = Memory.Map.Grid[x][z]
            local p = unit.part
            if p then
                local ui = p:FindFirstChild("NumberGui") or p:FindFirstChild("numbergui")
                if ui then
                    unit.hidden = false
                    unit.status = "number"
                    local lb = ui:FindFirstChildWhichIsA("TextLabel")
                    unit.val = lb and tonumber(lb.Text) or 0
                    table.insert(Memory.Map.Marked, unit)
                elseif p:FindFirstChild("Flag") or p:FindFirstChild("flag") then
                    unit.status = "flagged"
                else
                    unit.status = "unknown"
                    unit.hidden = true
                end
            end
        end
    end
end

-- Pathfinding move function
local function MoveToPosition(targetPos)
    local player = _P.LocalPlayer
    local character = player.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    local path = PathfindingService:CreatePath()
    path:ComputeAsync(rootPart.Position, targetPos + Vector3.new(0, 2, 0))
    if path.Status ~= Enum.PathStatus.Success then
        warn("Path not found to", targetPos)
        return
    end

    local waypoints = path:GetWaypoints()
    for _, waypoint in ipairs(waypoints) do
        rootPart.CFrame = CFrame.new(waypoint.Position + Vector3.new(0, 2, 0))
        -- Wait until the character reaches the waypoint
        repeat
            wait(0.1)
        until (rootPart.Position - waypoint.Position).Magnitude < 1
    end
    -- Final correction
    rootPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0))
    wait(0.2)
end

-- Auto-play: flag mines and walk to safe cells
local function AutoPlay()
    local player = _P.LocalPlayer
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end

    -- Flag all detected mines
    for unit, flagged in pairs(Memory.Map.ToFlag) do
        if flagged and unit.part then
            local flag = unit.part:FindFirstChild("Flag") or Instance.new("BoolValue")
            flag.Name = "Flag"
            flag.Value = true
            flag.Parent = unit.part
        end
    end

    -- Walk onto each safe cell
    for x = 0, Memory.Bounds.X - 1 do
        for z = 0, Memory.Bounds.Z - 1 do
            local unit = Memory.Map.Grid[x][z]
            if unit.status == "number" and not Memory.Map.ToFlag[unit] and not Memory.Map.ToClear[unit] then
                if unit.part then
                    MoveToPosition(unit.pos)
                    wait(0.2)
                end
            end
        end
    end
end

-- Main loop
_RS.Heartbeat:Connect(function()
    local folder = _W:FindFirstChild("Flag") and _W.Flag:FindFirstChild("Parts")
    if not folder or not Prefs.Active then return end

    if #folder:GetChildren() ~= Memory.Count then
        Memory.Count = #folder:GetChildren()
        MapOutEnvironment(folder)
        Memory.Pending = true
    end

    if Memory.Pending then
        Memory.Pending = false
        ScanGrid()
        Compute()

        -- Run auto-solving: flag mines and walk on safe cells
        AutoPlay()

        for x = 0, Memory.Bounds.X - 1 do
            for z = 0, Memory.Bounds.Z - 1 do
                local unit = Memory.Map.Grid[x][z]
                if unit.part then
                    if Memory.Map.ToFlag[unit] then RefreshBox(unit, "mine")
                    elseif Memory.Map.ToClear[unit] then RefreshBox(unit, "safe")
                    else RefreshBox(unit, "none") end
                end
            end
        end
    end
end)
